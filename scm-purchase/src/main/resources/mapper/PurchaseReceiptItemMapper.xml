<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.scm.purchase.mapper.PurchaseReceiptItemMapper">

    <resultMap id="purchaseReceiptItemResultMap" type="com.example.scm.purchase.entity.PurchaseReceiptItem">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="purchaseReceiptId" column="purchase_receipt_id"/>
        <result property="materialId" column="material_id"/>
        <result property="locationId" column="location_id"/>
        <result property="receiptQty" column="receipt_qty"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectByReceiptId" resultMap="purchaseReceiptItemResultMap">
        SELECT id, tenant_id, purchase_receipt_id, material_id, location_id, receipt_qty, created_at
        FROM purchase_receipt_item
        WHERE tenant_id = #{tenantId} AND purchase_receipt_id = #{purchaseReceiptId}
        ORDER BY id ASC
    </select>
</mapper>
